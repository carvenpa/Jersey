@model Category
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">@Localizer["DeleteMsg"]</h2>
            <hr />
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="CatName" class="p-0"></label> *@
            <label class="p-0">@Localizer["CategoryMsg"]</label>
            <input asp-for="CatName" disabled class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="DisplayOrder" class="p-0"></label> *@
            <label class="p-0">@Localizer["DisplayOrderMsg"]</label>
            <input asp-for="DisplayOrder" disabled class="form-control" />
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">
                    @Localizer["DeleteMsg"]
                </button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Category" asp-action="Index" class="btn btn-secondary border form-control">
                    @Localizer["BackToCategoryMsg"]
                </a>
            </div>
        </div>
    </div>
</form>
