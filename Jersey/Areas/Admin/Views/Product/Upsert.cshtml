@* @model Product *@
@model ProductVM
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

<form method="post" enctype="multipart/form-data">
    <input asp-for="Product.Id" hidden />    
    <input asp-for="Product.ImageUrl" hidden />
    <div class="row">
        <div class="col-10">
            <div class="border p-3 mt-4">
                <div class="row pb-2">
                    <h3 class="text-primary">@(Model.Product.Id != 0 ? @Localizer["EditMsg"] : @Localizer["AddNewProductMsg"])@Localizer["ProdLongMsg"]</h3>
                </div>
                <div class="row">
                    <div class="col-sm-5">
                        @* <label asp-for="Product.ProductName" class="p-0"></label> *@
                        <label class="p-0">@Localizer["ProductMsg"]</label>
                        <input asp-for="Product.ProductName" class="form-control" />
                        <span asp-validation-for="Product.ProductName" class="text-center text-bg-danger"></span>
                    </div>
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Season" class="p-0"></label> *@
                        <label class="p-0">@Localizer["SeasonMsg"]</label>
                        <input asp-for="Product.Season" class="form-control" />
                        <span asp-validation-for="Product.Season" class="text-center text-bg-danger"></span>
                    </div>
                
                    <div class="col-sm-5">
                        @* <label asp-for="Product.SleeveType" class="p-0"></label> *@
                        <label class="p-0">@Localizer["SleeveTypeMsg"]</label>
                        <input asp-for="Product.SleeveType" class="form-control" />
                        <span asp-validation-for="Product.SleeveType" class="text-center text-bg-danger"></span>
                    </div>
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Edition" class="p-0"></label> *@
                        <label class="p-0">@Localizer["EditionMsg"]</label>
                        <input asp-for="Product.Edition" class="form-control" />
                        <span asp-validation-for="Product.Edition" class="text-center text-bg-danger"></span>
                    </div>
                </div>    
                <div class="row">
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Size" class="p-0"></label> *@
                        <label class="p-0">@Localizer["SizeMsg"]</label>
                        <input asp-for="Product.Size" class="form-control" />
                        <span asp-validation-for="Product.Size" class="text-center text-bg-danger"></span>
                    </div>
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Price" class="p-0"></label> *@
                        <label class="p-0">@Localizer["PriceMsg"]</label>
                        <input asp-for="Product.Price" class="form-control" />
                        <span asp-validation-for="Product.Price" class="text-center text-bg-danger"></span>
                    </div>
                </div>
                <div class="row">    
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Description" class="p-0"></label> *@
                        <label class="p-0">@Localizer["DescriptionMsg"]</label>
                        <input asp-for="Product.Description" class="form-control" />
                        <span asp-validation-for="Product.Description" class="text-center text-bg-danger"></span>
                    </div>
                    <div class="col-sm-5">
                        @* <label asp-for="Product.Printing" class="p-0"></label> *@
                        <label class="p-0">@Localizer["PrintingColorMsg"]</label>
                        <input asp-for="Product.Printing" class="form-control" />
                        <span asp-validation-for="Product.Printing" class="text-center text-bg-danger"></span>
                    </div>
                </div>
                
                <div class="mb-3 row p-1">
                    @* <label asp-for="Product.ImageUrl" class="p-0"></label> *@
                    <label class="p-0">@Localizer["ImageUrlMsg"]</label>
                    <input type="file" name="file" asp-for="Product.ImageUrl" class="form-control" />   @* name of the input element is file, same as upsert method parameter *@            
                </div>
                <div class="mb-3 row p-1">
                    @* <label asp-for="Product.CategoryId" class="p-0"></label> *@
                    <label class="p-0">@Localizer["CategoryMsg"]</label>
                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select">
                        <option disabled selected>--@Localizer["SelectMsg"]--</option>
                    </select>
                    <span asp-validation-for="Product.CategoryId" class="text-center text-bg-danger"></span>
                </div>
                
                <div class="row">
                    <div class="col-6 col-md-3">
                        @if (Model.Product.Id != 0)
                        {
                            <button type="submit" class="btn btn-primary form-control">@Localizer["UpdateMsg"]</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary form-control">@Localizer["AddNewProductMsg"]</button>
                        }
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary border form-control">
                            @Localizer["BackToProductMsg"]
                        </a>
                    </div>
                </div>
            </div>
        </div>  
        <div class="col-2">
            <img class="mt-4" src="@Model.Product.ImageUrl" width="100%" height="50%" style="border-radius:5px; border:1px solid #bbb9b9" />
        </div>
    </div>
        
    
</form>

@* Client side validation by calling buildin Jquery under partial view page _ValidationScriptsPartial *@
@section Scripts{
    @{
        <partial name="_ValidationScriptsPartial"/> /* with jquery buildin */
    }
}