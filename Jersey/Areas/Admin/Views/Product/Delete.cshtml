@model Product

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Delete the League Team Jersey or International Team Jersey</h2>
            <hr />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="ProductName" class="p-0"></label>
            <input asp-for="ProductName" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Season" class="p-0"></label>
            <input asp-for="Season" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="SleeveType" class="p-0"></label>
            <input asp-for="SleeveType" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Edition" class="p-0"></label>
            <input asp-for="Edition" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Size" class="p-0"></label>
            <input asp-for="Size" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Price" class="p-0"></label>
            <input asp-for="Price" class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Description" class="p-0"></label>
            <input asp-for="Description" class="form-control" />
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Delete</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-secondary border form-control">
                    Back to Product Index Page
                </a>
            </div>
        </div>
    </div>
</form>
