@model Store
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">@Localizer["AddNewStoreMsg"]</h2>
            <hr />
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="Name" class="p-0"></label> *@
            <label class="p-0">@Localizer["StoreNameMsg"]</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="PhoneNumber" class="p-0"></label> *@
            <label class="p-0">@Localizer["TelMsg"]</label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="Address" class="p-0"></label> *@
            <label class="p-0">@Localizer["AddressMsg"]</label>
            <input asp-for="Address" class="form-control" />
            @* name of the input element is file, same as upsert method parameter *@     
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="District" class="p-0"></label> *@
            <label class="p-0">@Localizer["DistrictMsg"]</label>
            <input asp-for="District" class="form-control" />
            @* name of the input element is file, same as upsert method parameter *@     
            <span asp-validation-for="District" class="text-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            @* <label asp-for="Description" class="p-0"></label> *@
            <label class="p-0">@Localizer["DescriptionMsg"]</label>
            <input asp-for="Description" class="form-control" />
            @* name of the input element is file, same as upsert method parameter *@     
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">@Localizer["AddNewStoreMsg"]</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Store" asp-action="Index" class="btn btn-secondary border form-control">
                    @Localizer["BackToStoresListMsg"]
                </a>
            </div>
        </div>
    </div>
</form>

@* Client side validation by calling buildin Jquery under partial view page _ValidationScriptsPartial *@
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
        /* with jquery buildin */
    }
}