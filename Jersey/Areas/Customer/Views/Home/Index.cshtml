@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model IEnumerable<Product>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-lg-3 col-md-6">
            <div class="row p-2">
                <div class="col-12 p-1" style="border:1px solid #008cba; border-radius: 5px">
                    <div class="card">
                        <img src="@product.ImageUrl" class="card-img-top rounded">
                        <div class="card-body">
                            <div class="p-1">
                                <p class="card-title h5 text-primary">@product.ProductName</p>
                                <p class="active"><b>@Localizer["SizeMsg"] : @product.Size</b></p>
                            </div>
                            <div class="p-1">
                                <p>@Localizer["PriceMsg"]：<b>$@product.Price.ToString("0.00")</b></p>
                            </div>
                        </div>
                    </div>
                    <div>
                        <a asp-action="Details" class="btn btn-primary form-control" asp-route-productId="@product.Id">
                            @Localizer["DetailsMsg"]                            
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
